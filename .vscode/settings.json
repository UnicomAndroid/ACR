{
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/.dart_tool": true,
    "**/.idea": true,
    "**/build": true,

    // Hide ephemeral platform folders if you don't edit them directly
    "**/android": false,
    "**/ios": false,
    "**/linux": false,
    "**/macos": false,
    "**/web": false,
    "**/windows": false,
    "**/windows/flutter/ephemeral": true,
    "**/linux/flutter/ephemeral": true,
    "**/macos/Flutter/ephemeral": true,

    // Hide generated source files if using build_runner (Freezed, Injectable, etc.)
    "**/*.g.dart": true,
    "**/*.freezed.dart": true,
    "**/*.config.dart": true
  }
}
